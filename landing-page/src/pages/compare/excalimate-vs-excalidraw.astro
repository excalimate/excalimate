---
import PageLayout from '../../layouts/PageLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Callout from '../../components/Callout.astro';
import RelatedGuides from '../../components/RelatedGuides.astro';

const title = 'Excalimate vs Excalidraw: What\'s the Difference? — Excalimate';
const description = 'Compare Excalimate and Excalidraw. Understand how Excalimate extends Excalidraw with keyframe animation, timeline, camera controls, and AI-powered MCP tools.';
---

<PageLayout title={title} description={description} path="/compare/excalimate-vs-excalidraw">
  <Nav />

  <main id="main" class="guide">
    <div class="guide-container">
      <header class="guide-header">
        <a href="/compare" class="guide-back">← Back to comparisons</a>
        <h1 class="guide-title">Excalimate vs Excalidraw</h1>
        <p class="guide-subtitle">{description}</p>
      </header>

      <div class="guide-body">
        <!-- Versus intro cards -->
        <div class="versus-row">
          <div class="versus-card">
            <img src="/excalimate_logo.svg" alt="Excalimate" height="24" />
            <p class="versus-tagline">Excalidraw + keyframe animation + AI</p>
          </div>
          <span class="versus-vs">vs</span>
          <div class="versus-card">
            <h3 class="versus-name">Excalidraw</h3>
            <p class="versus-tagline">Open-source virtual whiteboard</p>
          </div>
        </div>

        <!-- Introduction -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Built on Excalidraw</h2>
          </div>
          <p class="step-text">
            Excalimate is not a competitor to Excalidraw — it's built <strong>on top of it</strong>.
            The full Excalidraw editor is embedded inside Excalimate, so you get the same
            hand-drawn aesthetic, the same tools, and the same file format. Excalimate adds a
            keyframe animation layer, a visual timeline, camera controls, and AI-powered creation
            tools via MCP.
          </p>
        </section>

        <!-- Feature comparison table -->
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr><th>Feature</th><th>Excalimate</th><th>Excalidraw</th></tr>
            </thead>
            <tbody>
              <tr><td>Hand-drawn diagram editor</td><td>✓</td><td>✓</td></tr>
              <tr><td>Real-time collaboration</td><td>✗</td><td>✓</td></tr>
              <tr><td>Keyframe animation</td><td>✓</td><td>✗</td></tr>
              <tr><td>Animation timeline</td><td>✓</td><td>✗</td></tr>
              <tr><td>Camera pan &amp; zoom animation</td><td>✓</td><td>✗</td></tr>
              <tr><td>Export to MP4 / GIF / WebM</td><td>✓</td><td>✗</td></tr>
              <tr><td>MCP / AI tools</td><td>✓ (23 tools)</td><td>✓</td></tr>
              <tr><td>Shareable links</td><td>✓</td><td>✓</td></tr>
              <tr><td>Open source</td><td>✓</td><td>✓</td></tr>
              <tr><td>Free to use</td><td>✓</td><td>✓</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Keyframe Animation -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Keyframe Animation</h2>
          </div>
          <p class="step-text">
            This is the core difference. Excalidraw creates static diagrams. Excalimate lets you
            animate every element with 7 properties: <strong>opacity</strong>,
            <strong>translateX/Y</strong>, <strong>scaleX/Y</strong>, <strong>rotation</strong>,
            and <strong>drawProgress</strong>. Each property can have unlimited keyframes with
            17 easing functions.
          </p>
        </section>

        <!-- Visual Timeline -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Visual Timeline</h2>
          </div>
          <p class="step-text">
            Excalimate includes a timeline panel where you can see all animation tracks, drag
            keyframes, adjust timing, and preview your animation in real-time. Excalidraw has
            no concept of time-based animation.
          </p>
        </section>

        <!-- Camera Controls -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Camera Animations</h2>
          </div>
          <p class="step-text">
            Excalimate adds a camera system that can pan, zoom, and frame your diagram over time.
            This is essential for presentation-style animations where you want to guide the
            viewer through different parts of a complex diagram.
          </p>
        </section>

        <!-- AI / MCP Integration -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">AI-Powered Creation (MCP)</h2>
          </div>
          <p class="step-text">
            Both Excalimate and Excalidraw offer MCP servers for AI integration. Excalimate's MCP server includes 23 specialized tools for creating elements, adding keyframe animations, controlling camera movements, and exporting — all through AI assistants like GitHub Copilot, Cursor, and Claude. Excalidraw's MCP server focuses on diagram creation and editing. If you need AI-powered animation control, Excalimate's toolset is significantly deeper.
          </p>
        </section>

        <!-- Export Formats -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Export Formats</h2>
          </div>
          <p class="step-text">
            Excalidraw exports static images (PNG, SVG). Excalimate exports animated content
            in 8 formats: <strong>MP4</strong>, <strong>WebM</strong>, <strong>GIF</strong>,
            <strong>dotLottie</strong>, <strong>Lottie JSON</strong>, <strong>SVG</strong>,
            <strong>PNG</strong>, and <strong>WebP</strong>.
          </p>
        </section>

        <!-- Real-time Collaboration -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Real-time Collaboration</h2>
          </div>
          <p class="step-text">
            Excalidraw.com supports real-time collaboration where multiple users can draw on the
            same canvas simultaneously. Excalimate does not currently support real-time multi-user
            editing, though you can share your projects via encrypted links.
          </p>
        </section>

        <!-- When to Use Each -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">When to Use Each</h2>
          </div>
          <ul class="step-list">
            <li><strong>Use Excalidraw</strong> when you need a quick static sketch, real-time collaboration with teammates, or a lightweight whiteboard</li>
            <li><strong>Use Excalimate</strong> when you want to animate your diagrams, create presentation-style walkthroughs, export video content, or use AI to build diagrams</li>
          </ul>
          <Callout type="info">
            Since Excalimate uses the same file format as Excalidraw, you can start a diagram in
            Excalidraw and bring it into Excalimate to add animation later.
          </Callout>
        </section>

        <!-- Verdict -->
        <section class="verdict">
          <h2 class="step-title">The Verdict</h2>
          <p class="step-text">
            Excalimate is the best choice when you want to <strong>animate your diagrams</strong>.
            For pure whiteboarding without animation, Excalidraw is excellent — and since
            Excalimate is built on it, you're not choosing between them. You're choosing whether
            you need animation on top.
          </p>
          <a href="https://app.excalimate.com" class="btn btn-primary" style="margin-top:20px">Open Excalimate</a>
        </section>
      </div>
      <RelatedGuides current="/compare/excalimate-vs-excalidraw" />
    </div>
  </main>

  <Footer />
</PageLayout>

<style>
  .guide {
    background: var(--bg);
    padding: 40px 0 80px;
  }

  .guide-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 640px) {
    .guide-container {
      padding: 0 32px;
    }
  }

  /* ── Header ── */
  .guide-header {
    margin-bottom: 56px;
  }

  .guide-back {
    display: inline-flex;
    align-items: center;
    font-family: var(--f-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--tx3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .guide-back:hover {
    color: var(--tx);
  }

  .guide-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: var(--tx);
    margin: 0;
  }

  .guide-subtitle {
    font-family: var(--f-body);
    font-size: 1.1rem;
    color: var(--tx2);
    margin: 12px 0 0;
    line-height: 1.5;
  }

  /* ── Steps ── */
  .guide-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    background: var(--accent);
    border: var(--border-w-sm) solid var(--border-c);
    box-shadow: 2px 2px 0 var(--border-c);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--tx);
    margin: 0;
    line-height: 1.3;
  }

  .step-text {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
  }

  .step-text :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .step-text :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
  }

  /* ── Inline code ── */
  .inline-code {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Step list ── */
  .step-list {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
    padding-left: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .step-list :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .step-list :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Versus cards ── */
  .versus-row { display: flex; gap: 16px; align-items: stretch; justify-content: center; flex-wrap: wrap; }
  .versus-card { flex: 1; min-width: 200px; max-width: 50%; padding: 20px; border: var(--border-w) solid var(--border-c); border-radius: var(--radius); box-shadow: var(--shadow-card); background: var(--card-bg); text-align: center; }
  .versus-card img { margin: 0 auto 8px; }
  .versus-vs { font-family: var(--f-sketch); font-size: 1.5rem; color: var(--p3); }
  .versus-name { font-family: var(--f-display); font-weight: 700; font-size: 1.1rem; color: var(--tx); margin: 0 0 6px; }
  .versus-tagline { font-family: var(--f-body); font-size: 0.85rem; color: var(--tx2); margin: 0; }

  /* ── Comparison table ── */
  .compare-table-wrap { overflow-x: auto; border: var(--border-w) solid var(--border-c); border-radius: var(--radius); box-shadow: var(--shadow-card); }
  .compare-table { width: 100%; border-collapse: collapse; font-family: var(--f-body); font-size: 0.9rem; }
  .compare-table th { background: var(--bg-alt); font-weight: 600; color: var(--tx); text-align: left; padding: 12px 16px; border-bottom: var(--border-w-sm) solid var(--border-c); }
  .compare-table td { padding: 10px 16px; border-bottom: 1px solid var(--border); color: var(--tx2); }
  .compare-table tr:last-child td { border-bottom: none; }

  /* ── Verdict ── */
  .verdict { text-align: center; padding-top: 40px; border-top: 1px solid var(--border); margin-top: 16px; }

  /* ── Buttons ── */
  .btn {
    display: inline-flex;
    align-items: center;
    font-family: var(--f-body);
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    padding: 10px 20px;
    border-radius: var(--radius);
    transition: background 0.2s, color 0.2s;
  }

  .btn-primary {
    background: var(--accent);
    color: var(--accent-text);
    border: var(--border-w-sm) solid var(--border-c);
    box-shadow: 3px 3px 0 var(--border-c);
  }

  .btn-primary:hover {
    box-shadow: 4px 4px 0 var(--border-c);
    transform: translate(-1px, -1px);
  }
</style>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'Excalimate vs Excalidraw: What\'s the Difference?',
    description,
    author: { '@type': 'Organization', name: 'Excalimate' },
    publisher: { '@type': 'Organization', name: 'Excalimate' },
  })}
/>
