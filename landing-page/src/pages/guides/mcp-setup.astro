---
import PageLayout from '../../layouts/PageLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RelatedGuides from '../../components/RelatedGuides.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const title = 'MCP Server Setup Guide — Excalimate';
const description =
  'Connect your AI coding assistant to Excalimate. Step-by-step setup for VS Code, Cursor, Claude Desktop, Claude Code, and Windsurf.';

const tools = [
  {
    id: 'vscode',
    name: 'VS Code (GitHub Copilot)',
    instruction: 'Create <code>.vscode/mcp.json</code> in your project:',
    label: '.vscode/mcp.json',
    code: `{
  "servers": {
    "excalimate": {
      "type": "http",
      "url": "http://localhost:3001/mcp"
    }
  }
}`,
  },
  {
    id: 'cursor',
    name: 'Cursor',
    instruction: 'Go to <strong>Settings → MCP Servers</strong>, then add:',
    label: undefined,
    code: `Name: excalimate
Type: http
URL:  http://localhost:3001/mcp`,
  },
  {
    id: 'claude-desktop',
    name: 'Claude Desktop',
    instruction:
      'Claude Desktop uses stdio mode (no live preview). Add to your <code>claude_desktop_config.json</code>:',
    label: 'claude_desktop_config.json',
    code: `{
  "mcpServers": {
    "excalimate": {
      "command": "npx",
      "args": ["@excalimate/mcp-server", "--stdio"]
    }
  }
}`,
  },
  {
    id: 'claude-code',
    name: 'Claude Code (CLI)',
    instruction: 'Start the server, then register it:',
    label: undefined,
    code: `npx @excalimate/mcp-server &
claude mcp add excalimate http://localhost:3001/mcp`,
  },
  {
    id: 'windsurf',
    name: 'Windsurf',
    instruction: 'Add to your <code>mcp_config.json</code>:',
    label: 'mcp_config.json',
    code: `{
  "mcpServers": {
    "excalimate": {
      "serverUrl": "http://localhost:3001/mcp"
    }
  }
}`,
  },
];
---

<PageLayout title={title} description={description} path="/guides/mcp-setup">
  <Nav />

  <main id="main" class="guide">
    <div class="guide-container">
      <!-- Header -->
      <header class="guide-header">
        <a href="/guides" class="guide-back">← Back to guides</a>
        <h1 class="guide-title">MCP Server Setup Guide</h1>
        <p class="guide-subtitle">Connect your AI coding assistant to Excalimate</p>
      </header>

      <div class="guide-body">
        <!-- Step 1 -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">1</span>
            <h2 class="step-title">Start the MCP server</h2>
          </div>
          <p class="step-text">
            Run the server with a single command. It starts in HTTP mode with live preview enabled
            by default.
          </p>
          <CodeBlock code="npx @excalimate/mcp-server" label="Terminal" />
          <p class="step-text">
            The server will listen on <code class="inline-code">http://localhost:3001/mcp</code>. To
            use a custom port:
          </p>
          <CodeBlock code="npx @excalimate/mcp-server --port 4000" />
        </section>

        <!-- Step 2 -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">2</span>
            <h2 class="step-title">Connect in Excalimate</h2>
          </div>
          <p class="step-text">
            Click the broadcast icon in the toolbar (top-right) to connect to the running server.
            Once connected, you'll see a live preview of everything the AI creates in real-time.
          </p>
          <p class="step-text">
            You can configure the server URL in <strong>File → Preferences</strong>.
          </p>
        </section>

        <!-- Step 3 -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">3</span>
            <h2 class="step-title">Configure your AI tool</h2>
          </div>
          <p class="step-text">
            Add the MCP server to your AI coding assistant. Pick your tool below:
          </p>

          {
            tools.map((tool) => (
              <div class="tool-section" id={tool.id}>
                <h3 class="tool-name">{tool.name}</h3>
                <p class="step-text" set:html={tool.instruction} />
                <CodeBlock code={tool.code} label={tool.label} />
              </div>
            ))
          }
        </section>

        <!-- Done -->
        <div class="guide-done">
          <p class="done-text">That's it! Ask your AI to create diagrams and animations.</p>
        </div>
      </div>
      <RelatedGuides current="/guides/mcp-setup" />
    </div>

  </main>

  <Footer />
</PageLayout>

<style>
  .guide {
    background: var(--bg);
    padding: 40px 0 80px;
  }

  .guide-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 640px) {
    .guide-container {
      padding: 0 32px;
    }
  }

  /* ── Header ── */
  .guide-header {
    margin-bottom: 56px;
  }

  .guide-back {
    display: inline-flex;
    align-items: center;
    font-family: var(--f-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--tx3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .guide-back:hover {
    color: var(--tx);
  }

  .guide-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: var(--tx);
    margin: 0;
  }

  .guide-subtitle {
    font-family: var(--f-body);
    font-size: 1.1rem;
    color: var(--tx2);
    margin: 12px 0 0;
    line-height: 1.5;
  }

  /* ── Steps ── */
  .guide-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    background: var(--accent);
    border: var(--border-w-sm) solid var(--border-c);
    box-shadow: 2px 2px 0 var(--border-c);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--tx);
    margin: 0;
    line-height: 1.3;
  }

  .step-text {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
  }

  .step-text :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .step-text :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
  }

  /* ── Inline code ── */

  .inline-code {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Tool sections ── */
  .tool-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .tool-name {
    font-family: var(--f-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--tx);
    margin: 0;
  }

  /* ── Done ── */
  .guide-done {
    text-align: center;
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .done-text {
    font-family: var(--f-sketch);
    font-size: 1.25rem;
    color: var(--p4);
    margin: 0;
  }
</style>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to set up Excalimate MCP Server',
    description:
      'Connect your AI coding assistant to Excalimate for AI-powered diagram animation creation.',
    step: [
      {
        '@type': 'HowToStep',
        name: 'Start the MCP server',
        text: 'Run npx @excalimate/mcp-server in your terminal. The server listens on http://localhost:3001/mcp.',
      },
      {
        '@type': 'HowToStep',
        name: 'Connect in Excalimate',
        text: 'Click the broadcast icon in the toolbar to connect to the running server for live preview.',
      },
      {
        '@type': 'HowToStep',
        name: 'Configure your AI tool',
        text: 'Add the MCP server to VS Code, Cursor, Claude Desktop, Claude Code, or Windsurf using the provided configuration.',
      },
    ],
    tool: [
      { '@type': 'HowToTool', name: 'VS Code with GitHub Copilot' },
      { '@type': 'HowToTool', name: 'Cursor' },
      { '@type': 'HowToTool', name: 'Claude Desktop' },
      { '@type': 'HowToTool', name: 'Claude Code CLI' },
      { '@type': 'HowToTool', name: 'Windsurf' },
    ],
  })}
/>
