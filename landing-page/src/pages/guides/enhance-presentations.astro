  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to Enhance Presentations with Animated Diagrams',
    description:
      'Learn how to use Excalimate animations in your presentations. Export as MP4, GIF, or Lottie to embed in PowerPoint, Google Slides, and Keynote.',
    step: [
      {
        '@type': 'HowToStep',
        name: 'Create your diagram in Excalimate',
        text: 'Design your diagram using the Excalidraw-powered editor and add keyframe animations for progressive reveal and emphasis.',
      },
      {
        '@type': 'HowToStep',
        name: 'Choose the right export format',
        text: 'Export as MP4 for PowerPoint and Keynote, GIF for Google Slides, or dotLottie for web-based presentation tools.',
      },
      {
        '@type': 'HowToStep',
        name: 'Embed in your presentation',
        text: 'Insert the exported animation file into your slide deck. Configure playback settings to auto-play or click-to-play.',
      },
      {
        '@type': 'HowToStep',
        name: 'Optimize timing',
        text: 'Keep animations under 10 seconds. Use 300-500ms delays between reveals to match your speaking pace.',
      },
    ],
  })}
/>
