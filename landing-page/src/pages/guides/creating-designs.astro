---
import PageLayout from '../../layouts/PageLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RelatedGuides from '../../components/RelatedGuides.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Callout from '../../components/Callout.astro';

const title = 'Creating Designs with MCP — Excalimate';
const description = 'Learn how to use the Excalimate MCP server to create diagrams, flowcharts, and designs through AI coding assistants.';
---

<PageLayout title={title} description={description} path="/guides/creating-designs">
  <Nav />

  <main id="main" class="guide">
    <div class="guide-container">
      <!-- Header -->
      <header class="guide-header">
        <a href="/guides" class="guide-back">← Back to guides</a>
        <h1 class="guide-title">Creating Designs with MCP</h1>
        <p class="guide-subtitle">Use your AI assistant to create diagrams, flowcharts, and designs directly in Excalimate</p>
      </header>

      <div class="guide-body">
        <!-- Introduction -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">1</span>
            <h2 class="step-title">Introduction</h2>
          </div>
          <p class="step-text">
            Once your MCP server is connected, you can ask your AI assistant to create any diagram
            directly in Excalimate. The AI has access to 8 scene/element tools for full control over
            your canvas — creating, updating, and removing elements at will.
          </p>
          <Callout type="tip">
            Always start by asking the AI to call <code>read_me</code> first — it loads the element
            format reference so the AI knows exactly how to create elements.
          </Callout>
        </section>

        <!-- Your First Diagram -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">2</span>
            <h2 class="step-title">Your First Diagram</h2>
          </div>
          <p class="step-text">
            Let's create a simple flowchart with three boxes connected by arrows. Just describe what
            you want in plain language:
          </p>
          <CodeBlock
            code="Create a simple flowchart with three steps: Research, Design, and Build. Connect them with arrows."
            label="Prompt"
          />
          <p class="step-text">
            Behind the scenes, the AI translates your request into MCP tool calls:
          </p>
          <CodeBlock
            code={`create_scene({
  elements: [
    rectangle("Research", x: 100, y: 200),
    rectangle("Design",   x: 400, y: 200),
    rectangle("Build",    x: 700, y: 200),
    arrow(from: "Research", to: "Design"),
    arrow(from: "Design",  to: "Build"),
  ]
})`}
            label="What the AI does"
          />
          <p class="step-text">
            The result appears instantly in the Excalimate live preview — three labeled boxes in a
            horizontal flow, connected by arrows.
          </p>
        </section>

        <!-- Element Types -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">3</span>
            <h2 class="step-title">Element Types</h2>
          </div>
          <p class="step-text">
            Here are the element types you can ask the AI to create:
          </p>
          <div class="element-list">
            <div class="tool-section">
              <h3 class="tool-name">rectangle</h3>
              <p class="step-text">Boxes, cards, containers — the most common building block.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">ellipse</h3>
              <p class="step-text">Circles, ovals — great for start/end nodes or emphasis.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">diamond</h3>
              <p class="step-text">Decision nodes — perfect for yes/no branches in flowcharts.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">text</h3>
              <p class="step-text">Standalone labels and annotations.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">arrow</h3>
              <p class="step-text">Connections between shapes, with start/end bindings to elements.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">line</h3>
              <p class="step-text">Plain lines without arrowheads — for separators and decorations.</p>
            </div>
          </div>
          <Callout type="info">
            All elements support the Excalidraw hand-drawn style. You can control
            <code>roughness</code> (0 = sharp, 1 = hand-drawn, 2 = extra sketchy) and
            <code>strokeWidth</code>.
          </Callout>
        </section>

        <!-- Styling Elements -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">4</span>
            <h2 class="step-title">Styling Elements</h2>
          </div>
          <p class="step-text">
            You can control colors, fills, stroke styles, and more — just describe the look you want.
            The AI maps your descriptions to Excalidraw's color palette and fill options.
          </p>
          <CodeBlock
            code="Make the Research box blue with a light blue fill, and the Build box green."
            label="Prompt"
          />
          <p class="step-text">
            Elements support solid fills, hatching, cross-hatching, and transparent backgrounds.
            You can also ask for specific stroke colors, dashed borders, or different font sizes for
            text labels.
          </p>
        </section>

        <!-- Modifying Designs -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">5</span>
            <h2 class="step-title">Modifying Designs</h2>
          </div>
          <p class="step-text">
            You don't have to get everything right on the first try. The MCP server provides tools to
            iteratively refine your design:
          </p>
          <div class="element-list">
            <div class="tool-section">
              <h3 class="tool-name">add_elements</h3>
              <p class="step-text">Add new elements to the existing canvas without replacing what's there.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">update_elements</h3>
              <p class="step-text">Change properties of existing elements — position, size, color, text.</p>
            </div>
            <div class="tool-section">
              <h3 class="tool-name">remove_elements</h3>
              <p class="step-text">Delete specific elements by ID.</p>
            </div>
          </div>
          <p class="step-text">
            Just describe the changes you want:
          </p>
          <CodeBlock
            code={`Add a fourth step called "Launch" after Build, and change the Research box to be wider.`}
            label="Prompt"
          />
          <p class="step-text">
            The AI will use <code class="inline-code">get_scene</code> to inspect the current canvas,
            then apply targeted updates — no need to recreate everything from scratch.
          </p>
        </section>

        <!-- Tips for Better Results -->
        <section class="step">
          <div class="step-header">
            <span class="step-num">6</span>
            <h2 class="step-title">Tips for Better Results</h2>
          </div>
          <ul class="tips-list">
            <li class="step-text">
              <strong>Be specific about layout</strong> — mention positions or say "horizontal flow" / "vertical flow" to guide placement.
            </li>
            <li class="step-text">
              <strong>Name your elements</strong> — it helps when modifying later, since the AI can reference them by name.
            </li>
            <li class="step-text">
              <strong>Ask for hand-drawn style explicitly</strong> if you want the sketchy Excalidraw look.
            </li>
            <li class="step-text">
              Use <code class="inline-code">get_scene</code> to inspect what's on the canvas before making changes.
            </li>
            <li class="step-text">
              Save checkpoints with <code class="inline-code">save_checkpoint</code> before major changes — you can always roll back.
            </li>
          </ul>
        </section>

        <!-- Done / Next -->
        <div class="guide-done">
          <p class="done-text">Ready to bring your designs to life?</p>
          <a href="/guides/animating-designs" class="btn btn-secondary">Next: Animating your designs →</a>
        </div>
      </div>
          <RelatedGuides current="/guides/creating-designs" />
    </div>

  </main>

  <Footer />
</PageLayout>

<style>
  .guide {
    background: var(--bg);
    padding: 40px 0 80px;
  }

  .guide-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 640px) {
    .guide-container {
      padding: 0 32px;
    }
  }

  /* ── Header ── */
  .guide-header {
    margin-bottom: 56px;
  }

  .guide-back {
    display: inline-flex;
    align-items: center;
    font-family: var(--f-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--tx3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .guide-back:hover {
    color: var(--tx);
  }

  .guide-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: var(--tx);
    margin: 0;
  }

  .guide-subtitle {
    font-family: var(--f-body);
    font-size: 1.1rem;
    color: var(--tx2);
    margin: 12px 0 0;
    line-height: 1.5;
  }

  /* ── Steps ── */
  .guide-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    background: var(--accent);
    border: var(--border-w-sm) solid var(--border-c);
    box-shadow: 2px 2px 0 var(--border-c);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--tx);
    margin: 0;
    line-height: 1.3;
  }

  .step-text {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
  }

  .step-text :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .step-text :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
  }

  /* ── Inline code ── */
  .inline-code {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Tool / element sections ── */
  .element-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .tool-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .tool-name {
    font-family: var(--f-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--tx);
    margin: 0;
  }

  /* ── Tips list ── */
  .tips-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding-left: 20px;
    margin: 0;
  }

  /* ── Done ── */
  .guide-done {
    text-align: center;
    padding: 32px 0;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .done-text {
    font-family: var(--f-sketch);
    font-size: 1.25rem;
    color: var(--p4);
    margin: 0;
  }
</style>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to create designs with Excalimate MCP',
    description:
      'Learn how to use the Excalimate MCP server to create diagrams, flowcharts, and designs through AI coding assistants.',
    step: [
      {
        '@type': 'HowToStep',
        name: 'Connect your AI assistant',
        text: 'Ensure your MCP server is running and connected. Ask the AI to call read_me first to load the element format reference.',
      },
      {
        '@type': 'HowToStep',
        name: 'Create your first diagram',
        text: 'Describe a flowchart in plain language. The AI translates your prompt into create_scene calls with rectangles, arrows, and labels.',
      },
      {
        '@type': 'HowToStep',
        name: 'Choose element types',
        text: 'Use rectangles, ellipses, diamonds, text, arrows, and lines to build any diagram type.',
      },
      {
        '@type': 'HowToStep',
        name: 'Style your elements',
        text: 'Describe colors, fills, and stroke styles. The AI maps descriptions to Excalidraw color palettes and fill options.',
      },
      {
        '@type': 'HowToStep',
        name: 'Modify and refine',
        text: 'Use add_elements, update_elements, and remove_elements to iteratively improve your design without starting over.',
      },
      {
        '@type': 'HowToStep',
        name: 'Follow best practices',
        text: 'Be specific about layout, name elements, use get_scene to inspect the canvas, and save checkpoints before major changes.',
      },
    ],
    tool: [
      { '@type': 'HowToTool', name: 'Excalimate MCP Server' },
      { '@type': 'HowToTool', name: 'AI Coding Assistant (VS Code Copilot, Cursor, Claude, etc.)' },
    ],
  })}
/>
