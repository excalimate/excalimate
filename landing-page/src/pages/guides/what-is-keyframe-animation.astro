    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Lists ── */
  .param-list {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
