---
import PageLayout from '../../layouts/PageLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RelatedGuides from '../../components/RelatedGuides.astro';
import CodeBlock from '../../components/CodeBlock.astro';
import Callout from '../../components/Callout.astro';

const title = 'Animated Designs in One Shot — Excalimate';
const description = 'Create complete animated diagrams with a single AI prompt using Excalimate create_animated_scene MCP tool. Elements, keyframes, camera, and export in one call.';

const promptExample = `Create an animated architecture diagram showing a Client, API Gateway, and Database. The Client should fade in first, then an arrow draws to the API Gateway which pops in, then another arrow draws to the Database which pops in. Use a 16:9 camera.`;

const sceneExample = `create_animated_scene({
  elements: [
    rectangle("Client",      x: 100, y: 200),
    rectangle("API Gateway", x: 450, y: 200),
    rectangle("Database",    x: 800, y: 200),
    arrow(from: "Client", to: "API Gateway"),
    arrow(from: "API Gateway", to: "Database"),
  ],
  keyframes: [
    // Client fades in
    { target: "client", opacity: 0, time: 0 },
    { target: "client", opacity: 1, time: 500 },
    // Arrow 1 draws
    { target: "arrow-1", drawProgress: 0, time: 500 },
    { target: "arrow-1", drawProgress: 1, time: 1200 },
    // API Gateway pops in
    { target: "gateway", scale: 0, time: 1200 },
    { target: "gateway", scale: 1, time: 1600,
      easing: "easeOutBack" },
    // Arrow 2 draws
    { target: "arrow-2", drawProgress: 0, time: 1600 },
    { target: "arrow-2", drawProgress: 1, time: 2300 },
    // Database pops in
    { target: "database", scale: 0, time: 2300 },
    { target: "database", scale: 1, time: 2700,
      easing: "easeOutBack" },
  ],
  cameraFrame: {
    aspectRatio: "16:9",
    width: 1000
  },
  clipEnd: 3200
})`;
---

<PageLayout title={title} description={description} path="/guides/animated-designs">
  <Nav />

  <main id="main" class="guide">
    <div class="guide-container">
      <!-- Header -->
      <header class="guide-header">
        <a href="/guides" class="guide-back">&larr; Back to guides</a>
        <h1 class="guide-title">Creating Animated Designs in One Shot</h1>
        <p class="guide-subtitle">Build complete animated diagrams with a single AI prompt</p>
      </header>

      <div class="guide-body">
        <!-- Introduction -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Introduction</h2>
          </div>
          <p class="step-text">
            The most powerful way to use Excalimate with AI is the <code class="inline-code">create_animated_scene</code>
            tool — it creates your entire diagram AND its animations in a single call.
            No back-and-forth, no multiple steps.
          </p>
          <Callout type="tip">
            This is the recommended approach for new projects. Tell your AI what you want to see,
            and it builds everything at once — elements, keyframes, camera, and clip range.
          </Callout>
        </section>

        <!-- The create_animated_scene Tool -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">The create_animated_scene Tool</h2>
          </div>
          <p class="step-text">
            This composite tool accepts everything needed to produce a finished animation:
          </p>
          <ul class="param-list">
            <li><code class="inline-code">elements</code> — the Excalidraw elements (shapes, text, arrows)</li>
            <li><code class="inline-code">keyframes</code> — animation keyframes for each element</li>
            <li><code class="inline-code">sequences</code> — reveal sequences for staggered appearances</li>
            <li><code class="inline-code">cameraFrame</code> — camera position and aspect ratio</li>
            <li><code class="inline-code">clipStart</code> / <code class="inline-code">clipEnd</code> — export time range</li>
          </ul>
          <p class="step-text">
            Only <code class="inline-code">elements</code> is required — everything else is optional.
            The AI decides which options to include based on your prompt.
          </p>
        </section>

        <!-- Example — Architecture Diagram -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Example — Architecture Diagram</h2>
          </div>
          <p class="step-text">
            Here's a complete example showing how a single prompt turns into an animated diagram.
          </p>
          <CodeBlock code={promptExample} label="Prompt" />
          <p class="step-text">
            The AI processes this prompt and calls <code class="inline-code">create_animated_scene</code> with
            all elements, keyframes, camera settings, and clip range in one shot:
          </p>
          <CodeBlock code={sceneExample} label="What the AI creates" />
          <p class="step-text">
            The result is a fully animated diagram — the Client fades in, an arrow draws to the
            API Gateway which pops in with a bounce, then another arrow draws to the Database
            which pops in the same way. All in about 3 seconds.
          </p>
        </section>

        <!-- Using AI Skills -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Using AI Skills</h2>
          </div>
          <p class="step-text">
            Excalimate includes 16 specialized AI skills for common diagram types. When your AI
            assistant loads these skills, it gains domain-specific knowledge for creating better
            diagrams of each type.
          </p>
          <ul class="skill-list">
            <li><strong>architecture-diagrams</strong> — cloud/system architecture</li>
            <li><strong>flowcharts</strong> — process flows and decision trees</li>
            <li><strong>sequence-diagrams</strong> — API call sequences</li>
            <li><strong>er-diagrams</strong> — database schemas</li>
            <li><strong>mind-maps</strong> — concept brainstorming</li>
            <li><strong>timeline-roadmaps</strong> — project timelines</li>
            <li><strong>org-charts</strong> — team hierarchies</li>
          </ul>
          <Callout type="info">
            Skills are loaded automatically by compatible AI assistants. They provide
            domain-specific knowledge for creating better diagrams of each type.
          </Callout>
        </section>

        <!-- Exporting Your Animation -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Exporting Your Animation</h2>
          </div>
          <p class="step-text">
            After creating your animated design, you can export it in several ways:
          </p>
          <ul class="param-list">
            <li><strong>From the Excalimate UI</strong> — use the export panel to choose format and quality</li>
            <li><strong>Via MCP</strong> — the AI can set the clip range with <code class="inline-code">set_clip_range</code></li>
          </ul>
          <p class="step-text">
            Supported export formats: MP4, WebM, GIF, SVG, dotLottie, Lottie JSON, PNG, and WebP.
          </p>
          <Callout type="tip">
            Use <strong>dotLottie</strong> for web — it's up to 90% smaller than GIF and supports transparency.
          </Callout>
        </section>

        <!-- Sharing -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Sharing</h2>
          </div>
          <p class="step-text">
            The <code class="inline-code">share_project</code> tool creates end-to-end encrypted
            share URLs for your animated designs. The encryption key lives in the URL hash
            fragment, so it is never sent to any server — only people with the link can view
            your work.
          </p>
        </section>

        <!-- Tips for Best Results -->
        <section class="step">
          <div class="step-header">
            <h2 class="step-title">Tips for Best Results</h2>
          </div>
          <ul class="tips-list">
            <li>Describe the diagram <strong>and</strong> the animation in one prompt</li>
            <li>Mention desired timing (e.g., "each element should appear 500ms after the previous one")</li>
            <li>Specify camera aspect ratio if you know the target (16:9 for video, 1:1 for social)</li>
            <li>Ask the AI to use <code class="inline-code">save_checkpoint</code> after creating — makes iteration easy</li>
            <li>For complex diagrams, start with <code class="inline-code">create_animated_scene</code> then refine with individual tools</li>
          </ul>
        </section>

        <!-- Navigation -->
        <div class="guide-nav">
          <a href="/guides/animating-designs" class="btn btn-secondary">&larr; Animating designs</a>
          <a href="/guides/mcp-setup" class="btn btn-secondary">MCP Setup Guide</a>
        </div>
      </div>
          <RelatedGuides current="/guides/animated-designs" />
    </div>

  </main>

  <Footer />
</PageLayout>

<style>
  .guide {
    background: var(--bg);
    padding: 40px 0 80px;
  }

  .guide-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 640px) {
    .guide-container {
      padding: 0 32px;
    }
  }

  /* ── Header ── */
  .guide-header {
    margin-bottom: 56px;
  }

  .guide-back {
    display: inline-flex;
    align-items: center;
    font-family: var(--f-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--tx3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color 0.2s;
  }

  .guide-back:hover {
    color: var(--tx);
  }

  .guide-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: clamp(2rem, 5vw, 2.75rem);
    line-height: 1.1;
    color: var(--tx);
    margin: 0;
  }

  .guide-subtitle {
    font-family: var(--f-body);
    font-size: 1.1rem;
    color: var(--tx2);
    margin: 12px 0 0;
    line-height: 1.5;
  }

  /* ── Steps ── */
  .guide-body {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius);
    background: var(--accent);
    border: var(--border-w-sm) solid var(--border-c);
    box-shadow: 2px 2px 0 var(--border-c);
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent-text);
    flex-shrink: 0;
  }

  .step-title {
    font-family: var(--f-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--tx);
    margin: 0;
    line-height: 1.3;
  }

  .step-text {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
  }

  .step-text :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .step-text :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
  }

  /* ── Inline code ── */

  .inline-code {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Tool sections ── */
  .tool-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .tool-name {
    font-family: var(--f-body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--tx);
    margin: 0;
  }

  /* ── Done ── */
  .guide-done {
    text-align: center;
    padding: 32px 0;
    border-top: 1px solid var(--border);
  }

  .done-text {
    font-family: var(--f-sketch);
    font-size: 1.25rem;
    color: var(--p4);
    margin: 0;
  }

  /* ── Lists ── */
  .param-list,
  .skill-list,
  .tips-list {
    font-family: var(--f-body);
    font-size: 0.95rem;
    color: var(--tx2);
    line-height: 1.7;
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .param-list :global(strong),
  .skill-list :global(strong),
  .tips-list :global(strong) {
    color: var(--tx);
    font-weight: 600;
  }

  .param-list :global(code),
  .skill-list :global(code),
  .tips-list :global(code) {
    font-size: 0.85em;
    padding: 2px 6px;
    border-radius: 4px;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    color: var(--tx);
    font-family: 'JetBrains Mono', 'Fira Code', Consolas, monospace;
  }

  /* ── Navigation ── */
  .guide-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: 'How to create animated designs in one shot with Excalimate',
    description:
      'Create complete animated diagrams with a single AI prompt using the create_animated_scene MCP tool.',
    datePublished: '2026-03-22',
    dateModified: '2026-03-22',
    step: [
      {
        '@type': 'HowToStep',
        name: 'Describe your diagram and animation',
        text: 'Write a single prompt describing the diagram elements, how they should animate, and the desired camera framing.',
      },
      {
        '@type': 'HowToStep',
        name: 'AI calls create_animated_scene',
        text: 'The AI uses the create_animated_scene tool to build elements, keyframes, sequences, camera, and clip range in one call.',
      },
      {
        '@type': 'HowToStep',
        name: 'Preview and refine',
        text: 'Preview the result in Excalimate live preview. Use save_checkpoint and refine with individual tools if needed.',
      },
      {
        '@type': 'HowToStep',
        name: 'Export or share',
        text: 'Export as MP4, WebM, GIF, dotLottie, or other formats. Share via E2E encrypted URLs with share_project.',
      },
    ],
  })}
/>
</script>
