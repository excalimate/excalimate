{
  "name": "@excalimate/mcp-server",
  "version": "0.3.0",
  "license": "MIT",
  "description": "Excalimate MCP server for creating Excalidraw designs and animating them with keyframes",
  "keywords": [
    "mcp",
    "excalidraw",
    "animation",
    "keyframe",
    "diagram"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excalimate/excalimate.git",
    "directory": "mcp-server"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "excalimate-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "SKILL.md",
    "references",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "nanoid": "^5.1.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}